#!/bin/sh
# pre-commit hook — blocks commits that would expose credentials.
#
# Checks:
#   1. application_config.h is not staged (contains WiFi/MQTT credentials)
#   2. No .pem, .key, .crt, .der files are staged (TLS certificates)

ERRORS=0

# Check for application_config.h
if git diff --cached --name-only | grep -q "application_config\.h$"; then
    echo "ERROR: application_config.h is staged for commit."
    echo "       This file contains credentials and must never be committed."
    echo "       Remove it with: git rm --cached app/IOT_SDK/config/application_config.h"
    ERRORS=1
fi

# Check for certificate/key files
CERT_FILES=$(git diff --cached --name-only | grep -E "\.(pem|key|crt|der)$")
if [ -n "$CERT_FILES" ]; then
    echo "ERROR: Certificate or key files are staged for commit:"
    echo "$CERT_FILES" | sed 's/^/         /'
    echo "       Remove them with: git rm --cached <file>"
    ERRORS=1
fi

if [ "$ERRORS" -ne 0 ]; then
    echo ""
    echo "Commit blocked. Fix the above and try again."
    exit 1
fi

exit 0
